# ==========================================================================
# Variables de entorno — copiar a `.env` y ajustar valores.
# El archivo `.env` real NUNCA se versiona (ver .gitignore).
# ==========================================================================

# ---------- PostgreSQL ----------
POSTGRES_DB=citas_entrega
POSTGRES_USER=app_user
POSTGRES_PASSWORD=changeme

# ---------- Backend (Django) ----------
SECRET_KEY=django-insecure-cambia-esta-clave-en-produccion
DEBUG=True
DJANGO_SETTINGS_MODULE=config.settings.dev
ALLOWED_HOSTS=localhost,127.0.0.1

# Cadena de conexión. Con Docker, el host es el nombre del servicio: `db`.
# En local sin Docker, usar `localhost`.
DATABASE_URL=postgres://app_user:changeme@db:5432/citas_entrega

# Orígenes permitidos para CORS (frontend Next.js)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ---------- Frontend (Next.js) ----------
NEXT_PUBLIC_API_URL=http://localhost:8000/api
